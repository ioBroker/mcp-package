{
  "name": "@iobroker/mcp-server",
  "version": "0.1.1",
  "description": "MCP server for ioBroker",
  "author": {
    "name": "ioBroker",
    "email": "info@iobroker.net"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/ioBroker/mpc-package",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "mcp",
    "server"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ioBroker/mpc-package"
  },
  "engines": {
    "node": ">=18.14.1"
  },
  "dependencies": {
    "@iobroker/type-detector": "^5.0.13",
    "@iobroker/webserver": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@alcalzone/release-script": "~5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "~5.2.0",
    "@alcalzone/release-script-plugin-license": "~5.2.0",
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@iobroker/types": "^7.2.2",
    "@tsconfig/node18": "^18.2.6",
    "@types/express": "^5.0.6",
    "@types/node": "^18.19.130",
    "typescript": "^6.0.3"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "build/",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "mocha --exit",
    "test:package": "echo \"No package tests required\" && exit 0",
    "test:integration": "mocha test/testAdapter.test.js --exit",
    "lint": "eslint -c eslint.config.mjs",
    "release": "release-script",
    "release-patch": "release-script patch --yes --no-update-lockfile",
    "release-minor": "release-script minor --yes --no-update-lockfile",
    "release-major": "release-script major --yes --no-update-lockfile"
  },
  "bugs": {
    "url": "https://github.com/ioBroker/mpc-package/issues"
  },
  "readmeFilename": "README.md"
}
